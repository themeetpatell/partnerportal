{
  "name": "finanshels-partner-portal",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "node ./scripts/dev.mjs",
    "dev:turbo": "turbo run dev",
    "db:generate": "corepack pnpm --filter @repo/db db:generate",
    "db:migrate": "corepack pnpm --filter @repo/db db:migrate",
    "db:push": "corepack pnpm --filter @repo/db db:push",
    "db:studio": "corepack pnpm --filter @repo/db db:studio",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.8.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.5.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.40.1"
    }
  }
}
