# Supabase Postgres
# Runtime app connection: Supabase pooler / Supavisor transaction mode
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Direct connection for Drizzle migrations and bootstrap SQL
DATABASE_URL_DIRECT=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
SUPABASE_PROJECT_REF=your-project-ref

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@finanshels.com

# Commissions — basis from lead (payment / proposal / manual) when finance creates a row from a won lead; VAT net optional
COMMISSION_CRM_AMOUNT_INCLUDES_VAT=true
COMMISSION_VAT_RATE_PCT=5

# App
NEXT_PUBLIC_PARTNER_APP_URL=https://partner.finanshels.com
NEXT_PUBLIC_ADMIN_APP_URL=https://collab.finanshels.com

# Internal — pricing engine / automation: GET /api/internal/partner-promo/v1/{CODE}
PARTNER_PROMO_LOOKUP_API_KEY=

# External pricing engine (Replit) — bidirectional integration
PRICING_ENGINE_BASE_URL=https://your-pricing-app.example.com
PRICING_ENGINE_API_KEY=
# POST path appended to BASE_URL (default shown)
PRICING_ENGINE_QUOTES_PATH=/api/portal/v1/quotes
# Webhook POST → Admin app: /api/integrations/pricing-engine/webhooks — HMAC SHA256 raw body
PRICING_ENGINE_WEBHOOK_SECRET=
# Allow webhook-driven pipeline moves + deal_won automation (set false to only sync quote rows + notes)
PRICING_ENGINE_AUTO_PIPELINE=true
# Partner app: minimum portal lead status before "Create proposal draft" is enabled
PRICING_ENGINE_PARTNER_MIN_STATUS=lead_approved
