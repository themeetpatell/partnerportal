{
  "name": "finanshels-partner-portal",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces --if-present build",
    "dev": "node ./scripts/dev.mjs",
    "dev:apps": "node ./scripts/dev.mjs",
    "db:bootstrap:supabase": "node ./scripts/db-bootstrap-supabase.mjs",
    "db:reset:supabase": "node ./scripts/db-reset-supabase.mjs",
    "db:generate": "npm run db:generate --workspace @repo/db",
    "db:migrate": "npm run db:migrate --workspace @repo/db",
    "db:push": "npm run db:push --workspace @repo/db",
    "db:seed": "node ./scripts/db-seed.mjs",
    "db:studio": "npm run db:studio --workspace @repo/db",
    "lint": "node ./node_modules/eslint/bin/eslint.js apps packages scripts --ext .js,.mjs,.ts,.tsx",
    "type-check": "npm run --workspaces --if-present type-check",
    "test": "npm run --workspaces --if-present test",
    "clean": "npm run --workspaces --if-present clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.5.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "drizzle-orm": "0.40.1"
  }
}
