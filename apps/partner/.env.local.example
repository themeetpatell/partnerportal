# Supabase Postgres
# Runtime app connection: Supabase pooler / Supavisor transaction mode
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Direct connection for Drizzle migrations and bootstrap SQL
DATABASE_URL_DIRECT=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
SUPABASE_PROJECT_REF=your-project-ref

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Zoho CRM
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_BASE_URL=https://www.zohoapis.com/crm/v3

# Zoho WorkDrive
ZOHO_WORKDRIVE_ACCESS_TOKEN=
ZOHO_WORKDRIVE_BASE_URL=https://workdrive.zoho.com/api/v1
ZOHO_WORKDRIVE_ROOT_FOLDER_ID=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@finanshels.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_PARTNER_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3001
